#!/usr/bin/env perl
# runpl — transpile and run an arbitrary Perl file through PCL.
#
# Usage:  ./runpl file.pl          # run a Perl file
#         echo 'print 1+2' | ./runpl   # run from stdin
#
# Generates /tmp/runpl_N.lisp (transpiled CL code)
# Prints filtered output to stdout.

use strict;
use warnings;
use File::Basename qw(dirname);
use Cwd qw(abs_path);
use File::Temp qw(tempfile);

my $root = abs_path(dirname($0));
my $lisp = "/tmp/runpl_$$.lisp";

# Get input: file arg or stdin
my $input_file;
if (@ARGV) {
    $input_file = shift;
    -f $input_file or die "File not found: $input_file\n";
} else {
    # Read stdin to temp file
    my ($fh, $fname) = tempfile('/tmp/runpl_stdin_XXXX', SUFFIX => '.pl', UNLINK => 1);
    print $fh $_ while <STDIN>;
    close $fh;
    $input_file = $fname;
}

# Transpile
system("perl -I$root $root/pl2cl --no-cache --lenient-ppi $input_file >$lisp 2>/tmp/runpl_$$.err");
if ($? != 0) {
    my $err = do { local $/; open(my $f,'<',"/tmp/runpl_$$.err") or die; <$f> };
    print STDERR "Transpile failed:\n$err";
    unlink $lisp, "/tmp/runpl_$$.err";
    exit 1;
}

# Run SBCL
my $raw = `sbcl --control-stack-size 512 --noinform --non-interactive --load $root/cl/pcl-runtime.lisp --eval "(setf pcl::*pcl-skip-cache* t)" --load $root/cl/pcl-test.lisp --load $lisp 2>&1`;

# Cleanup
unlink $lisp, "/tmp/runpl_$$.err";

# Filter SBCL noise and print
$raw =~ s/^;[^\n]*\n//gm;
$raw =~ s/^PCL (?:Runtime|Test)[^\n]*\n//gm;
$raw =~ s/^STYLE-WARNING[^\n]*\n//gm;
$raw =~ s/^\s*\n//gm;

print $raw;
